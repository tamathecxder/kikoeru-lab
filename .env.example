# Supabase — server-only access. NEXT_PUBLIC_SUPABASE_URL is safe to expose;
# SUPABASE_SERVICE_ROLE_KEY must NEVER reach the client (server routes only).
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini (Google AI Studio, free tier). Model: gemini-2.0-flash
GEMINI_API_KEY=

# Shared secret for the /api/ingest cron endpoint. Generate: openssl rand -hex 32
CRON_SECRET=
